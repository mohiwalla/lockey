{
	"name": "lockey",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"prettier": "^3.7.4",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"turbo": "^2.8.21",
		"typescript": "5.9.2",
		"vitepress": "^1.6.4"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
